# Top-level EditorConfig file
root = true

# All files
[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = crlf

# C# files
[*.cs]
indent_style = space
indent_size = 4
end_of_line = crlf

# Shader files
[*.shader]
end_of_line = crlf

# Compute shaders
[*.compute]
end_of_line = crlf

# JSON, YAML, text files
[*.json]
end_of_line = crlf

[*.yaml]
end_of_line = crlf

[*.txt]
end_of_line = crlf